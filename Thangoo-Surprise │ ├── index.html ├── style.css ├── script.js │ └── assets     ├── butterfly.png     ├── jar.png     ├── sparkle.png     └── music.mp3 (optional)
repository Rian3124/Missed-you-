body{

margin:0;
height:100vh;
overflow:hidden;

font-family:"Georgia",serif;

background:#020617;

color:white;

}



.scene{

display:none;

height:100vh;
width:100%;

position:absolute;

text-align:center;

overflow:hidden;

}



.scene.active{

display:block;

}





/* LOADER */


#loader{

position:fixed;

z-index:9999;

height:100vh;
width:100%;

background:#020617;

display:flex;

flex-direction:column;

align-items:center;

justify-content:center;

font-size:20px;

transition:2s;

}



#loader img{

width:120px;

animation:wing .5s infinite alternate;

}



#loader.fade{

opacity:0;

pointer-events:none;

}






/* SCENE 1 */


#scene1{

background:
linear-gradient(#020617,#172554);

}



.stars{

position:absolute;

height:100%;
width:100%;


background-image:

radial-gradient(white 1px,transparent 1px);


background-size:40px 40px;


animation:twinkle 3s infinite alternate;

}





.intro{

position:absolute;

top:38%;

width:100%;

animation:fade 3s;

}



.intro h1{

font-size:45px;

color:#cffafe;

text-shadow:

0 0 20px cyan;

}



.intro p{

font-size:22px;

}



.touch{

animation:pulse 2s infinite;

margin-top:40px;

}







/* BUTTERFLY */


.butterfly{

position:absolute;

width:120px;

left:-150px;

top:50%;


filter:

drop-shadow(0 0 25px cyan);



animation:

fly 10s linear infinite,
wing .5s infinite alternate;


}




@keyframes fly{


0%{

left:-150px;
top:55%;

}


50%{

left:50%;
top:35%;

}


100%{

left:110%;
top:55%;

}


}





@keyframes wing{

from{

transform:rotateY(0deg);

}

to{

transform:rotateY(45deg);

}

}









/* SCENE 2 */


#scene2{

background:

radial-gradient(circle,#1e40af,#020617);

}



.fingerButterfly{

position:absolute;

width:110px;

left:45%;
top:35%;


filter:

drop-shadow(0 0 30px cyan);



animation:

land 4s ease;

}



@keyframes land{


0%{

left:-100px;
opacity:0;

}


100%{

left:50%;
opacity:1;

}

}




.finger{

font-size:70px;

position:absolute;

bottom:25%;

left:47%;

}



.jar{

position:absolute;

bottom:15%;

left:40%;

opacity:1;

}



.jar img{

width:170px;

filter:

drop-shadow(0 0 40px cyan);

animation:

glow 2s infinite;

}








/* SCENE 3 */


.messageBox{


position:absolute;

top:18%;

left:7%;
right:7%;


padding:25px;


background:

rgba(255,255,255,.12);


border-radius:25px;


backdrop-filter:blur(10px);


box-shadow:

0 0 30px rgba(103,232,249,.5);


}



.smallButterfly{

width:80px;

}



#messageText{

font-size:21px;

line-height:1.6;

}




button{

border:none;

border-radius:30px;

padding:12px 25px;

font-size:18px;

cursor:pointer;

margin:15px;

}







/* SCENE 4 */


.fullJar img{

margin-top:15%;

width:200px;

filter:

drop-shadow(0 0 50px cyan);

}




.flyingButterflies img{

width:70px;

margin:15px;


animation:

float 3s infinite alternate;

}



.fadeText{

font-size:25px;

}








/* SCENE 5 */


.question{

padding-top:18%;

}



.lastButterfly{

width:120px;

filter:

drop-shadow(0 0 30px cyan);

animation:

float 3s infinite;

}



.question h1{

font-size:40px;

color:#fbcfe8;

}



#yesBtn{

background:#60a5fa;

color:white;

box-shadow:

0 0 25px #60a5fa;

}



#noBtn{

background:white;

position:absolute;

}








/* SCENE 6 */


.ending{

padding-top:25%;

animation:fade 3s;

}



.magic{

font-size:70px;

animation:float 2s infinite;

}



.ending p{

font-size:28px;

line-height:1.6;

}



.ending b{

color:#fda4af;

font-size:35px;

}









/* EFFECTS */


.sparkle{

position:absolute;

font-size:25px;

animation:

sparkleMove 2s infinite;

}



.heart{

position:absolute;

font-size:30px;

animation:

heartFly 2s forwards;

}





@keyframes sparkleMove{


50%{

transform:translateY(-40px);

opacity:.3;

}

}



@keyframes heartFly{


to{

transform:

translateY(-200px);

opacity:0;

}

}



@keyframes glow{


50%{

filter:

drop-shadow(0 0 60px cyan);

}

}




@keyframes float{


50%{

transform:translateY(-20px);

}

}



@keyframes pulse{


50%{

opacity:.5;

}

}



@keyframes twinkle{


from{

opacity:.3;

}

to{

opacity:1;

}

}



@keyframes fade{


from{

opacity:0;

}

to{

opacity:1;

}

}







/* MOBILE */


@media(max-width:600px){


.intro h1{

font-size:36px;

}


.intro p{

font-size:18px;

}



#messageText{

font-size:18px;

}


.question h1{

font-size:32px;

}



.magic{

font-size:50px;

}



.ending p{

font-size:22px;

}


