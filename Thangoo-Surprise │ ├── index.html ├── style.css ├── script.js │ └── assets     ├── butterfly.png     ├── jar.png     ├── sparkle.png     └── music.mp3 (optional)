let currentScene = 1;

let messageIndex = 0;

let musicStarted = false;



const music =
document.getElementById("bgMusic");





// LOADING SCREEN

window.addEventListener("load",()=>{


setTimeout(()=>{


document
.getElementById("loader")
.classList.add("fade");


},2500);



});








// CHANGE SCENE FUNCTION


function showScene(number){


document
.querySelectorAll(".scene")
.forEach(scene=>{

scene.classList.remove("active");

});



document
.getElementById("scene"+number)
.classList.add("active");



currentScene = number;


}









// FIRST TOUCH


document.body.addEventListener("click",()=>{



if(!musicStarted){


music.play()
.catch(()=>{});


musicStarted=true;


}



if(currentScene===1){


createSparkles();


showScene(2);



setTimeout(()=>{


document
.getElementById("jar")
.style.opacity="1";


},2500);



setTimeout(()=>{


showScene(3);

showMessage();


},5000);



}



});









// FIVE MESSAGES


const messages=[



`I don't say this enough… but you make my life complete ❤️

You make the normal days feel special… just by being there ✨

I know I mess up sometimes… and I'm really sorry for that 🥺

But no matter what… I always choose you ❤️

And today… I just want to see you smile 😊`,





`Thanks for turning this introvert into someone who can actually talk to anyone easily 😁`,






`Half the time I asked for lunch or outing… was just to spend a little more time with you 🤷‍♀️`,





`You are the first boy I ever spoke this much with… ❣️

THANKYOUUU for coming into my life like an angel 🔮😘

Thanks for standing beside me through all the situations and toughest times 😭🫶`,






`I didn't want you to go that far just to buy me a gift.

I just wanted you to be with me...

But I'm happy knowing that I can make a sacrifice for your happiness 😜`

];










// TYPEWRITER EFFECT


function showMessage(){


let text =
document.getElementById("messageText");


text.innerHTML="";



let message =
messages[messageIndex];



let i=0;



let timer =
setInterval(()=>{


text.innerHTML += message[i];


i++;



if(i>=message.length){


clearInterval(timer);


}



},35);



}








// NEXT BUTTON


document
.getElementById("nextMessage")
.addEventListener("click",()=>{



messageIndex++;



if(messageIndex < messages.length){


showMessage();


}

else{


showScene(4);



setTimeout(()=>{


showScene(5);


},5000);



}



});









// SPARKLES


function createSparkles(){



for(let i=0;i<30;i++){


let sparkle =
document.createElement("div");



sparkle.className="sparkle";

sparkle.innerHTML="✨";



sparkle.style.left =
Math.random()*100+"%";



sparkle.style.top =
Math.random()*100+"%";



document
.getElementById("scene2")
.appendChild(sparkle);



}


}









// NO BUTTON ESCAPE 😂


const noButton =
document.getElementById("noBtn");



noButton.addEventListener("mouseover",()=>{



let x =
Math.random()*70;


let y =
Math.random()*70;



noButton.style.transform =
`translate(${x}vw,${y}vh)`;


});









// YES BUTTON


document
.getElementById("yesBtn")
.addEventListener("click",()=>{



createHearts();


setTimeout(()=>{


showScene(6);



},1500);



});








// FINAL HEART EFFECT


function createHearts(){



for(let i=0;i<50;i++){



let heart =
document.createElement("div");



heart.className="heart";



heart.innerHTML=
["❤️","✨","🦋","🎉"][

Math.floor(Math.random()*4)

];



heart.style.left =
Math.random()*100+"vw";



heart.style.top =
Math.random()*100+"vh";



document
.body
.appendChild(heart);



}


}
